{
  "name": "@fimbul-works/seidr-router",
  "description": "Reactive router for Seidr",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "FimbulWorks <contact@fimbul.works>",
  "homepage": "https://github.com/fimbul-works/seidr-router#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fimbul-works/seidr-router.git"
  },
  "bugs": {
    "url": "https://github.com/fimbul-works/seidr-router/issues"
  },
  "keywords": [],
  "types": "./dist/seidr-router.d.ts",
  "exports": {
    ".": {
      "types": "./dist/seidr-router.d.ts",
      "import": "./dist/seidr-router.js",
      "require": "./dist/seidr-router.cjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "seidr-logo.svg",
    "README.md",
    "docs/*.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsdown",
    "test": "vitest",
    "format": "npx biome format --write src",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@fimbul-works/seidr": "1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@fimbul-works/seidr": "link:../seidr",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.10",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.4",
    "jsdom": "^26.0.0",
    "rollup": "^4.59.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "tsdown": "^0.21.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
