{
  "name": "@fimbul-works/seidr-router",
  "description": "Reactive router for Seidr",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "FimbulWorks <contact@fimbul.works>",
  "homepage": "https://github.com/fimbul-works/seidr-router#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fimbul-works/seidr-router.git"
  },
  "bugs": {
    "url": "https://github.com/fimbul-works/seidr-router/issues"
  },
  "keywords": [],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "seidr-logo.svg",
    "README.md",
    "docs/*.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "test": "vitest",
    "format": "npx biome format --write src",
    "prepublishOnly": "pnpm clean && npm run build"
  },
  "peerDependencies": {
    "@fimbul-works/seidr": "1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@fimbul-works/seidr": "link:../seidr",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
